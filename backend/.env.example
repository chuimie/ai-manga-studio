# Agnes AI（图片/文本/视频生成）
AGNES_API_KEY=你的Agnes API Key
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_TEXT_MODEL=agnes-2.0-flash
AGNES_IMAGE_MODEL=agnes-image-2.1-flash
AGNES_VIDEO_MODEL=agnes-video-v2.0

# MiMo TTS（语音合成）
MIMO_API_KEY=你的MiMo API Key
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# 本地配置
LOCAL_PORT=8000
ASSETS_PATH=../assets
CONFIG_PATH=config
MODELS_PATH=../models

# ── 训练模式 ──
# runpod = 云端GPU训练（API容器默认，不需要torch）
# local  = 本地CPU训练（lora-trainer容器用）
LORA_TRAIN_MODE=runpod

# ── 本地训练配置 ──
# HuggingFace模型ID 或 本地路径（首次会自动下载约1.7GB）
LOCAL_BASE_MODEL=runwayml/stable-diffusion-v1-5

# RunPod（LoRA云端训练）
RUNPOD_API_KEY=你的RunPod API Key
RUNPOD_LORA_ENDPOINT_ID=你的RunPod Serverless端点ID